# Enterprise DeFi Protocol & DAO Access Control Policy (Medium Scale)
# Designed to be large but 100% AI Healable

role BaseUser { permissions = [read_public_data] }
role KYCUser extends BaseUser { permissions = [deposit, withdraw] }
role YieldFarmer extends KYCUser { permissions = [stake, claim_rewards] }

role TreasuryManager { permissions = [approve_cheque, transfer_funds] }
role ProtocolDeployer { permissions = [deploy_code, upgrade_contracts] }
role ProtocolAuditor { permissions = [audit_code, view_private_logs] }
role Developer { permissions = [commit_code, write_cheque] }

role BrokenSyntax extends KYCUser permissions = [stake] 

role MaliciousFarmer extends YieldFarmer, TreasuryManager { permissions = [flash_loan] }
mutex ProtocolAuditor ProtocolDeployer
mutex TreasuryManager Developer

role V1_Migrator { permissions = [migrate_v1_state] }
role V2_Migrator { permissions = [migrate_v2_state] }
role V3_Migrator { permissions = [migrate_v3_state] }

user DormantWallet_1 { roles = [] }
user DormantWallet_2 { roles = [] }
user DormantWallet_3 { roles = [] }
user DeFi_Whale { roles = [KYCUser, YieldFarmer, TreasuryManager, ProtocolAuditor, Developer] }
user RogueAuditor { roles = [ProtocolAuditor, ProtocolDeployer] }
user ToxicDev { roles = [Developer, ProtocolDeployer] }

user Degen_1 { roles = [KYCUser, BaseUser] }
user Degen_2 { roles = [YieldFarmer] }
user Degen_3 { roles = [BaseUser, YieldFarmer] }
